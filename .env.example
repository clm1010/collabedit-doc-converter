PORT=3002
MAX_FILE_SIZE=200mb
MAX_CONCURRENT=5
IMPORT_TIMEOUT=30000
EXPORT_TIMEOUT=120000
LOG_LEVEL=info

# ---- Puppeteer (PDF 导出) ----
# CHROMIUM_EXECUTABLE_PATH：
#   - 留空 / 不设置：使用 Puppeteer 自带下载的 Chrome for Testing（Docker 场景默认路径）。
#   - 显式设置：用宿主机已安装的 Chrome（本地开发常用；无需再 pnpm install 下载一次 Chrome）。
#     Windows 示例： C:\Program Files\Google\Chrome\Application\chrome.exe
#     macOS   示例： /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#     Linux   示例： /usr/bin/google-chrome
#CHROMIUM_EXECUTABLE_PATH=
PDF_RENDER_TIMEOUT=60000
